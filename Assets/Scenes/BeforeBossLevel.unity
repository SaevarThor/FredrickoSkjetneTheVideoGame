--- !u!114 &575439637
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 575439636}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 64edfbda4ed525b41bc6eae0665435db, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  introTexts:
  - "This is it.\r\nNo choir.\r\nNo congregation.\r\nJust me\u2026 and the enemy."
  - "I stand on their stage.. \r\nBefore me is no god. \r\nIt's a misfired signal
    waiting to be silenced."
  - "It watches me.\r\nLike I\u2019m supposed to kneel.\r\nI don\u2019t know how
    to kneel. "
  - "It\u2019s big.\r\nIt\u2019s ancient.\r\nIt\u2019s angry.\r\n<So am I.>"
  - 'It offers me salvation.

    I brought my own. <Twelve gauge.>'
  - "No backup.\r\nNo miracles coming.\r\nJust one priest.\r\nOne shotgun.\r\nAnd
    one false god about to learn\r\n\r\n<When you reach far enough into the dark\u2026\r\nsometimes
    the Light hits back.>"
  textComponent: {fileID: 163875809}
  typingSpeed: 0.08
  pauseBetweenTexts: 1
  waitBeforeLoadingNextScene: 0
  isFirst: 0
  skipArray:
  - {fileID: 1364744994}
  - {fileID: 1364744993}
